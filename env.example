# Environment Variables Configuration Template
# Copy this file to .env and update with your actual values
# Command: cp env.example .env

# =====================================
# DATABASE CONFIGURATION
# =====================================

# For NeonDB (Production - Recommended):
DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require&channel_binding=require

# For Local PostgreSQL (Development):
# DATABASE_URL=postgresql://postgres:password@localhost:5432/fastapi_auth

# =====================================
# SECURITY
# =====================================

# JWT Secret Key - MUST be strong random value
# Generate with: openssl rand -hex 32
SECRET_KEY=your-64-character-random-secret-key-here

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =====================================
# API KEYS
# =====================================

# OpenAI API Key (required for AI features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Pinecone API Key (required for vector search/RAG)
# Get from: https://www.pinecone.io/
PINECONE_API_KEY=your-pinecone-api-key-here

# Google Custom Search (optional but recommended for web augmentation)
# Get API key from: https://developers.google.com/custom-search
# Create a Programmable Search Engine and copy the Search engine ID (cx)
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here

# =====================================
# APPLICATION SETTINGS
# =====================================

# Environment mode (development or production)
ENVIRONMENT=production

# LangSmith Tracing (optional - for observability/monitoring)
# Set to false to disable tracing and suppress warnings
# Get API key from: https://smith.langchain.com/
# LANGCHAIN_TRACING_V2=false
# LANGCHAIN_API_KEY=your-langsmith-api-key-here

# CORS Origins (comma-separated list)
# Use * for local development, but always specify concrete domains for production
CORS_ORIGINS=https://www.chataugustus.com,https://augustus-web-five.vercel.app

# Example: include additional staging domain
# CORS_ORIGINS=https://www.chataugustus.com,https://augustus-web-five.vercel.app,https://staging.chataugustus.com
